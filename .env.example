# =============================================
# PlanMaker 环境变量配置
# 复制此文件为 .env 并填入真实值
# =============================================

# ---- 应用环境 ----
APP_ENV=development

# ---- PostgreSQL ----
POSTGRES_USER=kaoyan
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=kaoyan
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ---- MongoDB ----
MONGO_USER=kaoyan
MONGO_PASSWORD=your_mongo_password_here
MONGO_DB=kaoyan
MONGO_PORT=27017

# ---- RabbitMQ ----
RABBITMQ_USER=kaoyan
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- MinIO ----
MINIO_ROOT_USER=kaoyan_minio
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- AI / LLM API ----
DASHSCOPE_API_KEY=your_llm_api_key_here

# ---- JWT ----
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# ---- 内部 API 密钥 (pdf-service 回调 server 时使用) ----
INTERNAL_API_KEY=your_internal_api_key_here

# ---- 微信小程序 (生产环境必填) ----
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ---- CORS (生产环境使用, 逗号分隔) ----
CORS_ALLOWED_ORIGINS=
