# MongoDB 配置 (完整连接字符串)
MONGO_URI=mongodb://username:password@host:port/database?authSource=admin

# RabbitMQ 配置 (完整连接字符串)
RABBITMQ_URL=amqp://username:password@host:port/

# Celery 配置
CELERY_BROKER_URL=amqp://username:password@host:port/
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO 配置
MINIO_SECRET_KEY=your_minio_secret_key_here

# 阿里云 DashScope / MiniMax API
DASHSCOPE_API_KEY=your_api_key_here

# CORS 允许的域名 (生产环境使用，逗号分隔)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com
